{
	"schemaVersion": 1,
	"id": "dm",
	"version": "${version}",

	"name": "Defensive Measures",
	"description": "Allows you to craft defensive turrets that will shoot any hostile mobs it detects, and defend villages that are within proximity.",
	"authors": [
		"Virus5600"
	],
	"contributors": [
		{
			"name": "avirtual777",
			"contact": {
				"homepage": "https://github.com/avirtual777"
			}
		},
		{
			"name": "Heimdallr-1",
			"contact": {
				"homepage": "https://github.com/Heimdallr-1"
			}
		}
	],
	"contact": {
		"issues": "https://github.com/Virus5600/Defensive-Measures-Mod/issues",
		"sources": "https://github.com/Virus5600/Defensive-Measures-Mod"
	},

	"license": "MIT",
	"icon": "assets/dm/icon.png",
	"accessWidener": "dm.accesswidener",

	"environment": "*",
	"mixins": [
		"dm.mixins.json",
		{
			"config": "dm.client.mixins.json",
			"environment": "client"
		}
