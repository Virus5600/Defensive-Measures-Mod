	"custom": {
		"loom:classtweaker": "dm.classtweaker",
		"modmenu": {
			"links": {
				"Curseforge": "https://www.curseforge.com/minecraft/mc-mods/defensive-measures",
				"Modrinth": "https://modrinth.com/mod/defensive-measures",
				"Planet Minecraft": "https://www.planetminecraft.com/mod/defensive-measures-mod/",
				"GitHub": "https://github.com/Virus5600/Defensive-Measures-Mod/releases",
				"Discord": "https://discord.gg/PCUKucADFr"
			},
			"update_checker": true
		}
	}
